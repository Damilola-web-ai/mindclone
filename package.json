{
  "name": "mindclone",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "check:env": "node scripts/validate-env.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "release:check": "npm run lint && npm run typecheck && npm run build",
    "smoke:deploy": "node scripts/smoke-deploy.mjs",
    "vercel:build": "npx vercel build --prod",
    "vercel:deploy:preview": "npx vercel",
    "vercel:deploy:prod": "npx vercel deploy --prebuilt --archive=tgz --prod"
  },
  "dependencies": {
    "@langchain/community": "^0.3.55",
    "@langchain/core": "^0.3.80",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.0",
    "mammoth": "^1.12.0",
    "next": "14.2.35",
    "pdf-parse": "^1.1.1",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "optionalDependencies": {
    "@next/swc-win32-x64-msvc": "^14.2.33"
  }
}
